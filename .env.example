# App
PORT=5000
NODE_ENV=development
# REQUIRED in production. Must be ≥16 chars. Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-in-prod-at-least-16-chars
INTEGRATION_MODE=stub                        # stub | live

# Database
DATABASE_PATH=/data/leads.db

# AI
OPENROUTER_API_KEY=
# Default per Zaki: Google Gemini Flash. Override with any OpenRouter model id.
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Confidence thresholds (tuneable post-launch)
CONFIDENCE_AUTO_SEND_THRESHOLD=0.80
CONFIDENCE_DRAFT_THRESHOLD=0.50

# Email (SendGrid)
SENDGRID_API_KEY=
EMAIL_FROM_ADDRESS=info@premiertreesllc.com
EMAIL_FROM_NAME=Premier Tree Specialists

# SMS / iMessage (Agent Phone)
AGENT_PHONE_API_KEY=
AGENT_PHONE_NUMBER=
SMS_PROVIDER=agent_phone                      # agent_phone | twilio
ENABLE_IMESSAGE=true

# ArboStar
ARBOSTAR_COMPANY_ID=
ARBOSTAR_API_KEY=

# Email inbound (Gmail polling for LSA + AnswerForce)
GMAIL_INBOUND_ADDRESS=agent@premiertreesllc.com
GMAIL_OAUTH_REFRESH_TOKEN=
LSA_EMAIL_FROM=noreply@google-business.com
ANSWERFORCE_EMAIL_FROM=notifications@answerforce.com
EMAIL_POLL_INTERVAL_SECONDS=60

# Webhook secrets
WEBSITE_FORM_WEBHOOK_SECRET=

# Agent Mail inbox — single forwarding alias the client sets in Gmail/AnswerForce/
# website filters. When empty, /settings shows a "Pending" placeholder for the
# client. Auto-derived from AGENT_MAIL_USERNAME@AGENT_MAIL_DOMAIN once the
# inbox is provisioned at boot; can be overridden manually if Sara provisions it.
AGENT_MAIL_ADDRESS=

# Agent Mail API access. When AGENT_MAIL_API_KEY is set, the server provisions
# the inbox + webhook idempotently at boot via the AgentMail SDK. Leave empty
# to skip provisioning (the /settings page falls back to "Pending").
AGENT_MAIL_API_KEY=
AGENT_MAIL_USERNAME=premier3-pts-agent
AGENT_MAIL_DOMAIN=agentmail.to
AGENT_MAIL_DISPLAY_NAME=Premier Tree Specialists Agent

# Public base URL used as the AgentMail webhook target. Required for live
# provisioning so AgentMail knows where to POST inbound emails. Example:
# https://premier-tree-pts.up.railway.app
PUBLIC_BASE_URL=

# Initial admin bootstrap (used only on a fresh DB with zero users — e.g. first
# Railway deploy). The server creates this user once at boot if the users table
# is empty; ignored otherwise. Set BOTH or NEITHER.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=Admin

# Reference data (zips + FAQs) and demo leads are bootstrapped automatically at
# boot whenever their tables are empty. Idempotent: real data is never
# overwritten. To start with an empty inbox in real production, manually
# delete the seeded demo leads from the dashboard or via SQL after first boot.

# One-shot reseed flag. When true, the server WIPES leads, source events,
# audit log, outbound messages, FAQs, and zip lookups at boot and re-inserts
# the rich demo set + reference data. Users, sessions, and app_settings are
# preserved. Use to push updated demo data to a Railway environment that
# already has rows. Toggle on, redeploy once, then turn back off — leaving
# this on will reset the DB on every restart.
RESEED_ON_BOOT=false
